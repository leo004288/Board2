<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- 
Windows -> Preferences -> xml -> xml(Wild Web Developer) -> 체크
namespace : com.green.menus.mapper.MenuMapper 인터페이스 위치 
-->
<mapper namespace="com.green.menus.mapper.MenuMapper">
	
	<select id="getMenuList"
	        resultType="com.green.menus.dto.MenuDTO">
			
	SELECT     MENU_ID, MENU_NAME, MENU_SEQ
	 FROM      MENUS
	 ORDER BY  MENU_SEQ ASC
	 	
	</select>
    
    <insert id="insertMenu">
    
    INSERT INTO MENUS ( MENU_ID, MENU_NAME, MENU_SEQ)
     VALUES ( #{menu_id}, #{menu_name}, #{menu_seq} )
    
    </insert>
    
</mapper>
